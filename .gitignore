# JWT Keys - Keep development keys, ignore production keys
# The keys in backend/src/main/resources/ are for development only
# For production, generate new keys and do NOT commit them
*.pem
!backend/src/main/resources/privateKey.pem
!backend/src/main/resources/publicKey.pem

